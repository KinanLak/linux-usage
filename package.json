{
  "name": "linux-usage",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node ./scripts/build-extension.mjs",
    "clean": "node ./scripts/build-extension.mjs --clean",
    "typecheck": "node ./scripts/typecheck-extension.mjs",
    "check": "npm run typecheck && npm run lint && npm run build",
    "lint": "oxlint src scripts --fix",
    "format": "oxfmt --write src scripts"
  },
  "devDependencies": {
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2"
  }
}
