{
  "name": "linux-usage",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "make build-esm",
    "build:legacy": "make build-legacy",
    "build:all": "make",
    "pack": "make pack-esm",
    "pack:legacy": "make pack-legacy",
    "pack:all": "make pack",
    "clean": "make clean-dist",
    "typecheck": "tsc",
    "check": "npm run typecheck && npm run lint && npm run build:all",
    "lint": "oxlint src --fix",
    "format": "oxfmt --write src"
  },
  "devDependencies": {
    "@girs/adw-1": "^1.10.0-4.0.0-beta.43",
    "@girs/clutter-14": "^14.0.0-4.0.0-beta.43",
    "@girs/gdk-4.0": "^4.0.0-4.0.0-beta.43",
    "@girs/gio-2.0": "^2.88.0-4.0.0-beta.43",
    "@girs/gjs": "^4.0.0-beta.43",
    "@girs/glib-2.0": "^2.88.0-4.0.0-beta.43",
    "@girs/gnome-shell": "^49.1.0",
    "@girs/gobject-2.0": "^2.88.0-4.0.0-beta.43",
    "@girs/gtk-4.0": "^4.22.1-4.0.0-beta.43",
    "@girs/meta-14": "^14.0.0-4.0.0-beta.43",
    "@girs/pango-1.0": "^1.57.0-4.0.0-beta.43",
    "@girs/soup-2.4": "^2.74.3-4.0.0-beta.43",
    "@girs/st-16": "^16.0.0-4.0.0-beta.43",
    "@types/node": "^25.5.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2"
  }
}
